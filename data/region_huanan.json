            {
              "name": "广东省博物馆",
              "level": 1,
              "address": "广东省广州市天河区珠江东路2号",
              "lng": 113.32,
              "lat": 23.118,
              "description": "广东省唯一的省级综合博物馆，馆藏文物丰富。",
              "treasures": [
                {
                  "name": "信宜铜盉",
                  "era": "西周",
                  "description": "1974年广东信宜出土，是广东出土的第一件西周青铜器，距今约3500年。",
                  "imageUrl": ""
                },
                {
                  "name": "千金猴王砚",
                  "era": "清代",
                  "description": "以端溪老坑大西洞石雕成，清末广东\"三大名砚\"之首，国宝级文物。",
                  "imageUrl": ""
                },
                {
                  "name": "金漆木雕大神龛",
                  "era": "清代",
                  "description": "高330厘米，是目前现存最大的潮州木雕大神龛，题材多样，雕饰精美。",
                  "imageUrl": ""
                },
                {
                  "name": "行书《陋室铭》卷",
                  "era": "元代",
                  "description": "赵孟頫所书，是其早年书法精品，被公认为赵孟頫早期书法代表作。",
                  "imageUrl": ""
                },
                {
                  "name": "北宋木雕罗汉像",
                  "era": "北宋",
                  "description": "现存唯一的宋代木雕五百罗汉群像，十分珍贵。",
                  "imageUrl": ""
                },
                {
                  "name": "元白玉镂雕龙穿牡丹盖钮",
                  "era": "元代",
                  "description": "以新疆和田青玉立体镂通琢成，图案极复杂，代表了元代雕刻最高水准。",
                  "imageUrl": ""
                },
                {
                  "name": "南宋鎏金腰带",
                  "era": "南宋",
                  "description": "南海I号沉船出水，长1.7米，重566克，由四股八条纯金金线编织，典型阿拉伯风格。",
                  "imageUrl": ""
                }
              ]
            },
            {
              "name": "广州博物馆",
              "level": 1,
              "address": "广东省广州市越秀区镇海路99号",
              "lng": 113.264,
              "lat": 23.137,
              "description": "位于镇海楼，是广州历史最悠久的博物馆。",
              "treasures": [
                {
                  "name": "镇海楼",
                  "era": "明代",
                  "description": "始建于1380年，被誉为\"五岭以南第一楼\"，是广州标志性古建筑。",
                  "imageUrl": ""
                }
              ]
            },
            {
              "name": "南越王博物院",
              "level": 1,
              "address": "广东省广州市越秀区解放北路867号",
              "lng": 113.262,
              "lat": 23.14,
              "description": "以南越国遗址和南越王墓为核心的大型遗址博物院。",
              "treasures": [
                {
                  "name": "丝缕玉衣",
                  "era": "西汉",
                  "description": "南越王赵眜墓出土，由2291片玉片用丝线编缀而成，是中国发现最早的丝缕玉衣。",
                  "imageUrl": ""
                },
                {
                  "name": "角形玉杯",
                  "era": "西汉",
                  "description": "青白玉雕成犀角形杯，杯口下方透雕云纹，首批禁止出国（境）展览文物。",
                  "imageUrl": ""
                },
                {
                  "name": "\"文帝行玺\"金印",
                  "era": "西汉",
                  "description": "含金量98%，重148.5克，龙钮方印，是目前考古发掘中发现的第一枚帝玺。",
                  "imageUrl": ""
                },
                {
                  "name": "铜屏风构件",
                  "era": "西汉",
                  "description": "首批禁止出国（境）展览文物，以鎏金人操蛇为造型，独具岭南特色。",
                  "imageUrl": ""
                },
                {
                  "name": "透雕龙凤纹重环玉佩",
                  "era": "西汉",
                  "description": "内圈透雕游龙，外圈透雕凤鸟，构图完美，被选为南越王博物院院徽。",
                  "imageUrl": ""
                },
                {
                  "name": "船纹铜提筒",
                  "era": "西汉",
                  "description": "筒壁刻有四组羽人划船纹，是南越文化的代表性器物。",
                  "imageUrl": ""
                },
                {
                  "name": "象牙珍品",
                  "era": "西汉",
                  "description": "南越王墓出土的完整象牙，象征南越国的财富与权力，是西汉时期南方与东南亚交流的实物证据。",
                  "imageUrl": ""
                }
              ]
