      "cities": [
        {
          "name": "台北市",
          "museums": [
            {
              "name": "台北故宫博物院",
              "level": 1,
              "address": "台湾省台北市士林区至善路二段221号",
              "lng": 121.5484,
              "lat": 25.1024,
              "description": "世界四大博物馆之一，收藏中华历代文物近70万件，以宋元明清宫廷收藏为核心，书画、陶瓷、铜器、玉器为四大特色。",
              "treasures": [
                {
                  "name": "翠玉白菜",
                  "era": "清代",
                  "description": "以一块半白半绿的翠玉雕刻而成，白色部分为菜帮，绿色为菜叶，叶上停有螽斯和蝗虫，寓意多子多孙、福寿绵延，为清代宫廷至宝。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/a3/Jadeite_Cabbage_by_PHGCOM.jpg/300px-Jadeite_Cabbage_by_PHGCOM.jpg"
                },
                {
                  "name": "肉形石",
                  "era": "清代",
                  "description": "天然玛瑙石，层次分明，纹理细腻，酷似一块肥瘦相间的东坡肉，令人叹为观止，被誉为「天下第一肉」。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/4/46/Meat-shaped_Stone.jpg/300px-Meat-shaped_Stone.jpg"
                },
                {
                  "name": "毛公鼎",
                  "era": "西周晚期",
                  "description": "高53.8厘米，铭文499字，是现存铭文最长的青铜器，完整记录周宣王册命毛公之事，史料价值无与伦比。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/5/5d/Mao_Gong_Ding.jpg/300px-Mao_Gong_Ding.jpg"
                },
                {
                  "name": "散氏盘",
                  "era": "西周晚期",
                  "description": "铭文357字，记载夨人割地赔偿散国的土地契约，是研究西周土地制度的重要文献，与毛公鼎、大盂鼎并称西周三大青铜器。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/6/61/San_Shi_Pan.jpg/400px-San_Shi_Pan.jpg"
                },
                {
                  "name": "宗周钟",
                  "era": "西周晚期",
                  "description": "周厉王时期铸造，钟身铭文122字，记载周厉王亲征南国的战绩，是西周晚期重要的礼乐器与史料。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/Zongzhou_zhong.jpg/400px-Zongzhou_zhong.jpg"
                },
                {
                  "name": "范宽《溪山行旅图》",
                  "era": "北宋",
                  "description": "纵206.3厘米，横103.3厘米，主峰巍峨耸立，气势逼人，为北宋山水画的巅峰之作，被誉为「中国绘画史上第一神品」。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/f/f3/Fan_Kuan_-_Travelers_Among_Mountains_and_Streams_-_Google_Art_Project.jpg/300px-Fan_Kuan_-_Travelers_Among_Mountains_and_Streams_-_Google_Art_Project.jpg"
                },
                {
                  "name": "郭熙《早春图》",
                  "era": "北宋",
                  "description": "描绘初春山间万物复苏之景，构图宏阔，云雾氤氲，为北宋宫廷画院最重要的山水画之一。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/4/44/Guo_Xi_-_Early_Spring_%28large%29.jpg/300px-Guo_Xi_-_Early_Spring_%28large%29.jpg"
                },
                {
                  "name": "汝窑天青无纹椭圆水仙盆",
                  "era": "北宋",
                  "description": "传世汝窑器中唯一的椭圆形水仙盆，釉色天青，如雨过天晴，极为珍稀。全球现存汝窑器不足百件，台北故宫藏品最多。",
                  "imageUrl": "https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Ru_ware_narcissus_basin%2C_NPM.jpg/400px-Ru_ware_narcissus_basin%2C_NPM.jpg"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}