                  "era": "唐代",
                  "description": "1970年何家村窖藏出土，选用罕见红色缠丝玛瑙制成，兽首口部镶金，首批禁止出国（境）展览文物。",
                  "imageUrl": ""
                },
                {
                  "name": "舞马衔杯纹银壶",
                  "era": "唐代",
                  "description": "何家村窖藏出土，仿游牧民族皮囊壶形制，壶身錾刻舞马衔杯图案。",
                  "imageUrl": ""
                },
                {
                  "name": "三彩载乐骆驼俑",
                  "era": "唐代",
                  "description": "骆驼上七位乐手演奏，展示了丝绸之路的文化交融，是唐三彩中的精品。",
                  "imageUrl": ""
                },
                {
                  "name": "葡萄花鸟纹银香囊",
                  "era": "唐代",
                  "description": "何家村窖藏出土，通体银质镂空，内层球体可自由旋转，无论怎样转动香料不会洒出。",
                  "imageUrl": ""
                },
